    "/api/v1/admin/platform/health",
    "/api/v1/admin/queue/status",
    "/api/v1/admin/system-monitoring",
    "/api/v1/admin/deployments",
    "/api/v1/admin/users",
    "/api/v1/admin/audit-logs",
    "/api/v1/admin/settings",
    "/api/v1/admin/manifest"
