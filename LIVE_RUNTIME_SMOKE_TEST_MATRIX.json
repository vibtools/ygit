      "required": true,
      "execution": "script"
    },
    {
      "id": "phase_2",
      "name": "auth_boundary",
      "required": true,
      "execution": "manual + script with test cookie"
    },
    {
      "id": "phase_3",
      "name": "user_flow_smoke",
      "required": true,
      "execution": "manual controlled test account"
    },
    {
      "id": "phase_4",
      "name": "worker_runtime",
      "required": true,
      "execution": "manual + logs + job status"
    },
    {
      "id": "phase_5",
      "name": "admin_operations_console",
      "required": true,
      "execution": "script with admin test cookie"
    },
    {
      "id": "phase_6",
      "name": "negative_secret_exposure",
      "required": true,
      "execution": "script + manual log review"
    },
    {
      "id": "phase_7",
      "name": "provider_boundary",
      "required": true,
      "execution": "boundary only; no real deploy required"
