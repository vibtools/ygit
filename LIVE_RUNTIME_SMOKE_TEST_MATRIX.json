  "public_endpoints": [
    "/api/v1/platform/health",
    "/api/v1/platform/version",
    "/dashboard",
    "/admin"
  ],
  "authenticated_endpoints": [
    "/api/v1/me",
    "/api/v1/platform/status",
    "/api/v1/platform/feature-flags",
    "/api/v1/projects",
    "/api/v1/notifications/unread-count"
