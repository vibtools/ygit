APP_NAME=YGIT
APP_ENV=development
APP_VERSION=0.1.0
APP_BASE_URL=http://localhost:8000
API_PREFIX=/api/v1
DEBUG=true

DATABASE_URL=postgresql+asyncpg://ygit:ygit_password@postgres:5432/ygit
REDIS_URL=redis://redis:6379/0

SESSION_SECRET=change-me-in-production-use-at-least-32-chars
SESSION_COOKIE_NAME=ygit_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_TTL_SECONDS=28800
AUTH_FLOW_TTL_SECONDS=600

TOKEN_ENCRYPTION_KEY=change-me-in-production-use-at-least-32-chars
TOKEN_ENCRYPTION_KEY_VERSION=v1

KEYCLOAK_ISSUER=https://auth.vib.tools/realms/vib
KEYCLOAK_REALM=vib
KEYCLOAK_CLIENT_ID=ygit
KEYCLOAK_CLIENT_SECRET=change-me-in-production
KEYCLOAK_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback
KEYCLOAK_POST_LOGOUT_REDIRECT_URI=http://localhost:8000/
OIDC_SCOPE=openid profile email
OIDC_HTTP_TIMEOUT_SECONDS=10
POST_LOGIN_REDIRECT_PATH=/dashboard

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
LOG_LEVEL=INFO
WORKER_ID=local-worker-1
QUEUE_NAME=default

# Connected Accounts Module v0.1.0
# Live provider OAuth exchange is not enabled in this module release.
# Keep real provider credentials in deployment secrets, not in Git.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
CLOUDFLARE_OAUTH_CLIENT_ID=
CLOUDFLARE_OAUTH_CLIENT_SECRET=

# Worker Runtime
WORKER_ID=local-worker-1
QUEUE_NAME=default
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_MAX_ATTEMPTS=3
